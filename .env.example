# ============================================================
# FVE Dashboard — konfigurace
# Zkopíruj jako /opt/fve-dashboard/.env a uprav hodnoty
# ============================================================

# Home Assistant URL (interní IP v Proxmox síti)
HA_URL=http://192.168.1.100:8123

# Long-Lived Access Token z Home Assistant
# Vytvoříš v HA: Profil → Security → Long-Lived Access Tokens → Create Token
HA_TOKEN=TVUJ_DLOUHY_TOKEN_ZDE

# Prefix tvého zařízení v Home Assistant
# Zjistíš v HA → Developer Tools → States → hledej entity začínající sensor.*_pv_power
# Pokud máš sensor.inverter_pv_power → DEVICE_PREFIX=inverter
# Pokud máš sensor.deye_pv_power → DEVICE_PREFIX=deye
DEVICE_PREFIX=deye

# Výstupní adresář pro generovaný HTML
OUTPUT_DIR=/var/www/html

# Maximální výkon FVE v wattech (pro gauge na stránce)
# Nastav podle špičkového výkonu tvé instalace
MAX_POWER=6000

# ============================================================
# Volitelné přepisy entity names
# Odkomentuj a uprav jen pokud tvé entity neodpovídají
# výchozímu naming patternu sensor.<DEVICE_PREFIX>_<name>
# ============================================================
# ENTITY_PV_POWER=sensor.deye_pv_power
# ENTITY_DAILY_PRODUCTION=sensor.deye_today_production
# ENTITY_TOTAL_PRODUCTION=sensor.deye_total_production
# ENTITY_PV1_VOLTAGE=sensor.deye_pv1_voltage
# ENTITY_PV2_VOLTAGE=sensor.deye_pv2_voltage
# ENTITY_PV1_POWER=sensor.deye_pv1_power
# ENTITY_PV2_POWER=sensor.deye_pv2_power
# ENTITY_AC_POWER=sensor.deye_power
# ENTITY_AC_FREQUENCY=sensor.deye_grid_frequency
# ENTITY_TEMPERATURE=sensor.deye_temperature
# ENTITY_DAILY_CONSUMPTION=sensor.deye_today_load_consumption
# ENTITY_DAILY_EXPORT=sensor.deye_today_energy_export
# ENTITY_DAILY_IMPORT=sensor.deye_today_energy_import
# ENTITY_BATTERY_SOC=sensor.deye_battery
# ENTITY_BATTERY_POWER=sensor.deye_battery_power
